          <div class="tool-fgroup"><label class="tool-label">IEC Standard</label><select class="tool-select" id="cfgIEC"><option value="IEC-61400-12-1-2017">IEC 61400-12-1:2017</option><option value="IEC-61400-12-1-2005">IEC 61400-12-1:2005</option></select></div>
          <div class="tool-fgroup"><label class="tool-label">Sector Width</label><select class="tool-select" id="cfgSector"><option value="10">10 degrees (36 sectors)</option><option value="20">20 degrees (18 sectors)</option></select></div>
          <div class="tool-fgroup"><label class="tool-label">Assessment Radius (m)</label><input class="tool-input" type="number" id="cfgRadius" value="5000" min="1000" max="20000"></div>
