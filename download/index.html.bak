            <span style="font-size:.6rem;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:.3rem"><span style="display:inline-block;width:10px;height:10px;background:#2d9cce;border-radius:50%"></span> Target WTG</span>
            <span style="font-size:.6rem;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:.3rem"><span style="display:inline-block;width:10px;height:10px;background:rgba(255,255,255,.25);border-radius:50%"></span> Other WTG</span>
            <span style="font-size:.6rem;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:.3rem"><span style="display:inline-block;width:10px;height:10px;background:#f0a500;transform:rotate(45deg)"></span> External WTG</span>
